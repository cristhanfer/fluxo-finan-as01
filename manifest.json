<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Fluxo">
<meta name="theme-color" content="#4ade80">
<title>Fluxo · Controle Financeiro</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0f0d;
    --surface: #111815;
    --surface2: #182118;
    --border: #1e2b22;
    --accent: #4ade80;
    --accent2: #86efac;
    --danger: #f87171;
    --warning: #fbbf24;
    --text: #e8f5ec;
    --muted: #5a7a62;
    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bottom: env(safe-area-inset-bottom, 0px);
  }
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  html, body { height:100%; overflow:hidden; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    display: flex;
    flex-direction: column;
    padding-top: var(--safe-top);
    padding-bottom: var(--safe-bottom);
  }
  body::before {
    content:'';
    position:fixed;
    inset:0;
    background:
      radial-gradient(ellipse 60% 40% at 80% 10%, rgba(74,222,128,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(74,222,128,0.04) 0%, transparent 70%);
    pointer-events:none;
    z-index:0;
  }

  /* ── TOP BAR ── */
  .topbar {
    position: relative; z-index:10;
    background: rgba(10,15,13,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: .9rem 1.2rem;
    display: flex; align-items:center; justify-content:space-between;
    flex-shrink:0;
  }
  .logo { font-family:'DM Serif Display',serif; font-size:1.5rem; color:var(--accent); letter-spacing:-1px; }
  .logo em { color:var(--muted); font-style:italic; font-size:.85rem; margin-left:.3rem; }
  .month-nav { display:flex; align-items:center; gap:.5rem; }
  .month-nav button { background:var(--surface2); border:1px solid var(--border); color:var(--muted); width:30px; height:30px; border-radius:50%; cursor:pointer; font-size:1rem; transition:.2s; }
  .month-nav button:active { border-color:var(--accent); color:var(--accent); transform:scale(.92); }
  #current-month { font-family:'DM Mono',monospace; font-size:.78rem; color:var(--text); min-width:100px; text-align:center; }

  /* ── SCROLL AREA ── */
  .scroll-area { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; position:relative; z-index:1; }
  .scroll-area::-webkit-scrollbar { display:none; }
  .inner { padding: 1rem 1rem 2rem; max-width:600px; margin:0 auto; }

  /* ── SUMMARY CARDS ── */
  .summary { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; margin-bottom:.75rem; }
  .card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; padding:1rem 1.1rem; position:relative; overflow:hidden;
  }
  .card::after { content:''; position:absolute; top:0;left:0;right:0; height:2px; background:var(--lc,var(--border)); border-radius:2px 2px 0 0; }
  .card.income { --lc: var(--accent); }
  .card.expense { --lc: var(--danger); }
  .card.balance { grid-column:1/-1; --lc: var(--warning); }
  .card-label { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:.3rem; }
  .card-value { font-family:'DM Serif Display',serif; font-size:1.5rem; line-height:1; }
  .card.income .card-value { color:var(--accent); }
  .card.expense .card-value { color:var(--danger); }
  .card.balance .card-value { color:var(--warning); font-size:1.7rem; }
  .card-sub { font-size:.68rem; color:var(--muted); margin-top:.25rem; font-family:'DM Mono',monospace; }

  /* ── ALERT ── */
  .budget-alert {
    background:rgba(251,191,36,0.08); border:1px solid rgba(251,191,36,0.25);
    border-radius:10px; padding:.75rem 1rem;
    display:flex; align-items:center; gap:.6rem; margin-bottom:.75rem;
  }
  .budget-alert.hidden { display:none; }
  .budget-alert span { font-size:.78rem; color:var(--warning); }

  /* ── ADD FORM ── */
  .add-section {
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; padding:1rem 1.1rem; margin-bottom:.75rem;
  }
  .add-section h3 { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:.8rem; }
  .type-toggle { display:grid; grid-template-columns:1fr 1fr; gap:.5rem; margin-bottom:.8rem; }
  .type-btn {
    border:1px solid var(--border); background:transparent; color:var(--muted);
    border-radius:10px; padding:.6rem; cursor:pointer; font-size:.82rem;
    font-family:'DM Sans',sans-serif; transition:.15s; touch-action:manipulation;
  }
  .type-btn.active.income { border-color:var(--accent); background:rgba(74,222,128,0.1); color:var(--accent); }
  .type-btn.active.expense { border-color:var(--danger); background:rgba(248,113,113,0.1); color:var(--danger); }
  .fields { display:grid; gap:.6rem; }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
  label.lbl { font-size:.65rem; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); display:block; margin-bottom:.25rem; }
  input, select {
    background:var(--surface2); border:1px solid var(--border);
    color:var(--text); border-radius:10px; padding:.65rem .85rem;
    font-family:'DM Sans',sans-serif; font-size:.9rem;
    outline:none; transition:.2s; width:100%;
    -webkit-appearance:none; appearance:none;
  }
  input:focus, select:focus { border-color:var(--accent); }
  input[type=number]::-webkit-inner-spin-button { -webkit-appearance:none; }
  .btn-add {
    width:100%; margin-top:.6rem;
    background:var(--accent); color:#000;
    border:none; border-radius:10px; padding:.75rem;
    font-family:'DM Sans',sans-serif; font-weight:700; font-size:.95rem;
    cursor:pointer; transition:.15s; touch-action:manipulation;
    letter-spacing:.02em;
  }
  .btn-add:active { background:var(--accent2); transform:scale(.98); }

  /* ── TRANSACTIONS ── */
  .tx-section {
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; overflow:hidden;
  }
  .tx-header {
    padding:.9rem 1.1rem; border-bottom:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between;
  }
  .tx-header h3 { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); }
  .filter-tabs { display:flex; gap:.4rem; }
  .filter-tab {
    background:none; border:1px solid transparent; color:var(--muted);
    border-radius:20px; padding:.25rem .7rem; font-size:.72rem;
    cursor:pointer; transition:.15s; font-family:'DM Sans',sans-serif;
  }
  .filter-tab.active { border-color:var(--accent); color:var(--accent); background:rgba(74,222,128,0.08); }

  /* ── Chart row ── */
  .chart-row { display:grid; grid-template-columns:140px 1fr; gap:1rem; padding:1rem 1.1rem; border-bottom:1px solid var(--border); align-items:center; }
  canvas { max-width:140px; max-height:140px; }
  .cat-list { display:flex; flex-direction:column; gap:.55rem; }
  .cat-item { display:flex; align-items:center; gap:.5rem; }
  .cat-emoji { font-size:.85rem; width:20px; }
  .cat-name { font-size:.75rem; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cat-bar-wrap { width:60px; background:var(--surface2); border-radius:4px; height:4px; }
  .cat-bar { height:100%; background:var(--danger); border-radius:4px; transition:width .5s ease; }
  .cat-pct { font-family:'DM Mono',monospace; font-size:.68rem; color:var(--muted); width:28px; text-align:right; }

  /* ── TX LIST ── */
  .tx-list { list-style:none; }
  .tx-item {
    display:flex; align-items:center; gap:.75rem;
    padding:.9rem 1.1rem; border-top:1px solid var(--border);
    transition:.15s; position:relative; overflow:hidden;
  }
  .tx-item.swipe-delete { transform:translateX(-80px); }
  .tx-icon { width:34px; height:34px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:.95rem; flex-shrink:0; }
  .tx-icon.income { background:rgba(74,222,128,0.12); }
  .tx-icon.expense { background:rgba(248,113,113,0.12); }
  .tx-info { flex:1; min-width:0; }
  .tx-desc { font-size:.88rem; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .tx-cat { font-size:.68rem; color:var(--muted); margin-top:.1rem; }
  .tx-meta { text-align:right; flex-shrink:0; }
  .tx-amount { font-family:'DM Mono',monospace; font-size:.88rem; font-weight:500; }
  .tx-amount.income { color:var(--accent); }
  .tx-amount.expense { color:var(--danger); }
  .tx-date { font-size:.65rem; color:var(--muted); margin-top:.1rem; }
  .tx-del {
    position:absolute; right:0; top:0; bottom:0;
    width:70px; background:var(--danger);
    border:none; color:#fff; font-size:.75rem; font-family:'DM Sans',sans-serif;
    cursor:pointer; display:flex; align-items:center; justify-content:center;
    transform:translateX(100%); transition:.2s;
  }
  .tx-item:hover .tx-del,
  .tx-item.show-del .tx-del { transform:none; }

  .empty-state { padding:2.5rem; text-align:center; color:var(--muted); font-size:.85rem; }
  .empty-icon { font-size:2rem; margin-bottom:.5rem; }

  /* ── INSTALL TOAST ── */
  .install-toast {
    position:fixed; bottom:calc(1rem + var(--safe-bottom)); left:50%;
    transform:translateX(-50%); z-index:100;
    background:var(--surface2); border:1px solid var(--accent);
    border-radius:14px; padding:.9rem 1.2rem;
    display:flex; align-items:center; gap:.75rem;
    box-shadow:0 8px 32px rgba(0,0,0,0.5);
    max-width:320px; width:90%;
    animation: slideUp .4s ease;
  }
  @keyframes slideUp { from { opacity:0; transform:translateX(-50%) translateY(20px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }
  .install-toast.hidden { display:none; }
  .install-toast p { font-size:.8rem; color:var(--text); flex:1; }
  .install-toast p strong { color:var(--accent); display:block; margin-bottom:.2rem; }
  .toast-btn { background:var(--accent); color:#000; border:none; border-radius:8px; padding:.45rem .85rem; font-size:.78rem; font-weight:700; cursor:pointer; white-space:nowrap; font-family:'DM Sans',sans-serif; }
  .toast-close { background:none; border:none; color:var(--muted); cursor:pointer; font-size:1rem; padding:.2rem; }

  @keyframes slideIn { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:none; } }
  .tx-item { animation: slideIn .25s ease; }
</style>
</head>
<body>

<div class="topbar">
  <div class="logo">fluxo<em>· finanças</em></div>
  <div class="month-nav">
    <button id="prev-month">‹</button>
    <span id="current-month"></span>
    <button id="next-month">›</button>
  </div>
</div>

<div class="scroll-area">
  <div class="inner">

    <!-- Summary -->
    <div class="summary">
      <div class="card income">
        <div class="card-label">Receitas</div>
        <div class="card-value" id="total-income">R$ 0</div>
        <div class="card-sub" id="income-count">0 entradas</div>
      </div>
      <div class="card expense">
        <div class="card-label">Despesas</div>
        <div class="card-value" id="total-expense">R$ 0</div>
        <div class="card-sub" id="expense-count">0 saídas</div>
      </div>
      <div class="card balance">
        <div class="card-label">Saldo do Mês</div>
        <div class="card-value" id="balance">R$ 0</div>
        <div class="card-sub" id="balance-pct">—</div>
      </div>
    </div>

    <!-- Alert -->
    <div class="budget-alert hidden" id="budget-alert">
      <span>⚠️</span>
      <span id="budget-alert-text"></span>
    </div>

    <!-- Add Form -->
    <div class="add-section">
      <h3>Nova transação</h3>
      <div class="type-toggle">
        <button class="type-btn expense active" id="btn-expense" onclick="setType('expense')">− Despesa</button>
        <button class="type-btn income" id="btn-income" onclick="setType('income')">+ Receita</button>
      </div>
      <div class="fields">
        <div>
          <label class="lbl">Descrição</label>
          <input type="text" id="tx-desc" placeholder="Ex: Aluguel, Salário…" autocomplete="off">
        </div>
        <div class="field-row">
          <div>
            <label class="lbl">Valor (R$)</label>
            <input type="number" id="tx-amount" placeholder="0,00" min="0" step="0.01" inputmode="decimal">
          </div>
          <div>
            <label class="lbl">Categoria</label>
            <select id="tx-cat">
              <option value="Alimentação">🍽 Alimentação</option>
              <option value="Transporte">🚌 Transporte</option>
              <option value="Moradia">🏠 Moradia</option>
              <option value="Saúde">💊 Saúde</option>
              <option value="Lazer">🎮 Lazer</option>
              <option value="Educação">📚 Educação</option>
              <option value="Salário">💼 Salário</option>
              <option value="Freelance">💻 Freelance</option>
              <option value="Investimento">📈 Investimento</option>
              <option value="Outros">📦 Outros</option>
            </select>
          </div>
        </div>
        <button class="btn-add" onclick="addTransaction()">Adicionar ＋</button>
      </div>
    </div>

    <!-- Transactions -->
    <div class="tx-section">
      <div class="tx-header">
        <h3>Transações</h3>
        <div class="filter-tabs">
          <button class="filter-tab active" onclick="setFilter('all',this)">Todas</button>
          <button class="filter-tab" onclick="setFilter('income',this)">Receitas</button>
          <button class="filter-tab" onclick="setFilter('expense',this)">Despesas</button>
        </div>
      </div>

      <!-- Mini chart + categories -->
      <div class="chart-row" id="chart-row">
        <canvas id="donut-chart" width="140" height="140"></canvas>
        <div class="cat-list" id="cat-breakdown"></div>
      </div>

      <ul class="tx-list" id="tx-list"></ul>
    </div>

  </div>
</div>

<!-- Install Toast -->
<div class="install-toast hidden" id="install-toast">
  <p><strong>📲 Instalar no celular</strong>Adicione à tela inicial para usar como app!</p>
  <button class="toast-btn" id="install-btn">Instalar</button>
  <button class="toast-close" onclick="document.getElementById('install-toast').classList.add('hidden')">✕</button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
// ── State ──
let transactions = JSON.parse(localStorage.getItem('fluxo_tx') || '[]');
let currentType = 'expense';
let currentFilter = 'all';
let viewDate = new Date();
let chart = null;
let deferredPrompt = null;

const CATS = {
  'Alimentação':'🍽','Transporte':'🚌','Moradia':'🏠','Saúde':'💊',
  'Lazer':'🎮','Educação':'📚','Salário':'💼','Freelance':'💻',
  'Investimento':'📈','Outros':'📦'
};

function save() { localStorage.setItem('fluxo_tx', JSON.stringify(transactions)); }
function fmtBRL(n) { return 'R$ '+n.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtDate(iso) { return new Date(iso).toLocaleDateString('pt-BR',{day:'2-digit',month:'short'}); }

function setType(t) {
  currentType = t;
  document.getElementById('btn-income').className='type-btn income'+(t==='income'?' active':'');
  document.getElementById('btn-expense').className='type-btn expense'+(t==='expense'?' active':'');
}

function setFilter(f,el) {
  currentFilter = f;
  document.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  render();
}

function getMonthTxs() {
  return transactions.filter(tx => {
    const d = new Date(tx.date);
    return d.getFullYear()===viewDate.getFullYear() && d.getMonth()===viewDate.getMonth();
  });
}

function addTransaction() {
  const desc = document.getElementById('tx-desc').value.trim();
  const amount = parseFloat(document.getElementById('tx-amount').value);
  const cat = document.getElementById('tx-cat').value;
  const descEl = document.getElementById('tx-desc');
  if (!desc || !amount || amount <= 0) {
    descEl.style.borderColor = 'var(--danger)';
    setTimeout(() => descEl.style.borderColor = '', 1200);
    return;
  }
  transactions.unshift({ id:Date.now(), desc, amount, cat, type:currentType, date:new Date().toISOString() });
  save();
  document.getElementById('tx-desc').value = '';
  document.getElementById('tx-amount').value = '';
  render();
  // Scroll to transactions
  setTimeout(() => document.querySelector('.tx-section').scrollIntoView({behavior:'smooth', block:'start'}), 100);
}

function deleteTransaction(id) {
  transactions = transactions.filter(t => t.id !== id);
  save();
  render();
}

function render() {
  document.getElementById('current-month').textContent =
    viewDate.toLocaleDateString('pt-BR',{month:'short',year:'numeric'});

  const monthTxs = getMonthTxs();
  const income = monthTxs.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const expense = monthTxs.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const bal = income - expense;

  document.getElementById('total-income').textContent = fmtBRL(income);
  document.getElementById('total-expense').textContent = fmtBRL(expense);
  document.getElementById('balance').textContent = fmtBRL(bal);
  document.getElementById('income-count').textContent = monthTxs.filter(t=>t.type==='income').length + ' entradas';
  document.getElementById('expense-count').textContent = monthTxs.filter(t=>t.type==='expense').length + ' saídas';

  const pctEl = document.getElementById('balance-pct');
  if (income > 0) {
    const pct = ((bal/income)*100).toFixed(0);
    pctEl.textContent = (bal >= 0 ? '▲ ' : '▼ ') + Math.abs(pct) + '% da receita';
  } else { pctEl.textContent = '—'; }

  // Alert
  const alertEl = document.getElementById('budget-alert');
  if (income > 0 && expense/income > 0.85) {
    alertEl.classList.remove('hidden');
    document.getElementById('budget-alert-text').textContent =
      `Despesas (${fmtBRL(expense)}) = ${Math.round(expense/income*100)}% da receita. Cuidado!`;
  } else { alertEl.classList.add('hidden'); }

  // Transaction list
  let filtered = monthTxs;
  if (currentFilter === 'income') filtered = monthTxs.filter(t=>t.type==='income');
  if (currentFilter === 'expense') filtered = monthTxs.filter(t=>t.type==='expense');

  const list = document.getElementById('tx-list');
  if (!filtered.length) {
    list.innerHTML = '<li class="empty-state"><div class="empty-icon">🌱</div>Nenhuma transação aqui.</li>';
  } else {
    list.innerHTML = filtered.map(tx => `
      <li class="tx-item" id="tx-${tx.id}">
        <div class="tx-icon ${tx.type}">${CATS[tx.cat]||'📦'}</div>
        <div class="tx-info">
          <div class="tx-desc">${tx.desc}</div>
          <div class="tx-cat">${tx.cat}</div>
        </div>
        <div class="tx-meta">
          <div class="tx-amount ${tx.type}">${tx.type==='income'?'+':'-'} ${fmtBRL(tx.amount)}</div>
          <div class="tx-date">${fmtDate(tx.date)}</div>
        </div>
        <button class="tx-del" onclick="deleteTransaction(${tx.id})">🗑 Excluir</button>
      </li>
    `).join('');
    // swipe to reveal delete
    filtered.forEach(tx => {
      const el = document.getElementById('tx-'+tx.id);
      let startX = 0;
      el.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, {passive:true});
      el.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - startX;
        if (dx < -50) el.classList.add('show-del');
        else el.classList.remove('show-del');
      }, {passive:true});
    });
  }

  // Donut chart
  const ctx = document.getElementById('donut-chart').getContext('2d');
  if (chart) chart.destroy();
  const hasData = income > 0 || expense > 0;
  chart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Receitas','Despesas'],
      datasets: [{
        data: hasData ? [income, expense] : [1,1],
        backgroundColor: ['rgba(74,222,128,0.85)','rgba(248,113,113,0.85)'],
        borderColor: ['#0a0f0d'],
        borderWidth: 2,
        hoverOffset: 3
      }]
    },
    options: {
      cutout: '68%',
      plugins: {
        legend: { display:false },
        tooltip: { callbacks: { label(c){ return ' '+fmtBRL(c.raw); } } }
      }
    }
  });

  // Category breakdown
  const expTxs = monthTxs.filter(t=>t.type==='expense');
  const catMap = {};
  expTxs.forEach(t=>{ catMap[t.cat]=(catMap[t.cat]||0)+t.amount; });
  const sorted = Object.entries(catMap).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const catEl = document.getElementById('cat-breakdown');
  if (!sorted.length) {
    catEl.innerHTML = '<div style="color:var(--muted);font-size:.75rem">Sem despesas no mês</div>';
  } else {
    const max = sorted[0][1];
    catEl.innerHTML = sorted.map(([cat,val]) => `
      <div class="cat-item">
        <span class="cat-emoji">${CATS[cat]||'📦'}</span>
        <span class="cat-name">${cat}</span>
        <div class="cat-bar-wrap"><div class="cat-bar" style="width:${Math.round(val/max*100)}%"></div></div>
        <span class="cat-pct">${expense>0?Math.round(val/expense*100):0}%</span>
      </div>
    `).join('');
  }
}

// Month nav
document.getElementById('prev-month').onclick = () => { viewDate.setMonth(viewDate.getMonth()-1); render(); };
document.getElementById('next-month').onclick = () => { viewDate.setMonth(viewDate.getMonth()+1); render(); };

// Enter key
['tx-desc','tx-amount'].forEach(id => {
  document.getElementById(id).addEventListener('keydown', e => { if(e.key==='Enter') addTransaction(); });
});

// PWA install prompt
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  setTimeout(() => document.getElementById('install-toast').classList.remove('hidden'), 2000);
});
document.getElementById('install-btn').onclick = async () => {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  const { outcome } = await deferredPrompt.userChoice;
  deferredPrompt = null;
  document.getElementById('install-toast').classList.add('hidden');
};
window.addEventListener('appinstalled', () => {
  document.getElementById('install-toast').classList.add('hidden');
});

// Service Worker
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  });
}

// Demo data
if (!transactions.length) {
  const now = new Date(); const m=now.getMonth(); const y=now.getFullYear();
  transactions = [
    {id:1,desc:'Salário',amount:5000,cat:'Salário',type:'income',date:new Date(y,m,1).toISOString()},
    {id:2,desc:'Aluguel',amount:1500,cat:'Moradia',type:'expense',date:new Date(y,m,5).toISOString()},
    {id:3,desc:'Mercado',amount:420,cat:'Alimentação',type:'expense',date:new Date(y,m,8).toISOString()},
    {id:4,desc:'Plano de Saúde',amount:250,cat:'Saúde',type:'expense',date:new Date(y,m,10).toISOString()},
    {id:5,desc:'Netflix',amount:75,cat:'Lazer',type:'expense',date:new Date(y,m,12).toISOString()},
    {id:6,desc:'Uber',amount:180,cat:'Transporte',type:'expense',date:new Date(y,m,15).toISOString()},
    {id:7,desc:'Freelance',amount:800,cat:'Freelance',type:'income',date:new Date(y,m,18).toISOString()},
  ];
  save();
}

render();
</script>
</body>
</html>
